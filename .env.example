# --- Notion ---
# Create an internal integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxx
# The Notion page where the setup script will create your databases.
# Share that page with your integration, then paste its ID here (32 chars from the page URL).
NOTION_PARENT_PAGE_ID=

# Filled in automatically by `npm run setup`:
NOTION_MEALS_DB=
NOTION_PLAN_DB=
NOTION_FREEZER_DB=

# --- Todoist ---
# Get your token at Todoist -> Settings -> Integrations -> Developer
TODOIST_TOKEN=
TODOIST_PROJECT=Groceries

# --- Household defaults ---
ADULT_PORTIONS=2
PROTEIN_TARGET=30
CALORIE_TARGET=750
